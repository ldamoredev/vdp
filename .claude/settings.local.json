{
  "permissions": {
    "allow": [
      "Bash(pnpm install:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm --filter:*)",
      "Bash(npx drizzle-kit:*)",
      "Bash(npx tsc:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose down:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker build:*)",
      "Bash(curl -s http://localhost:*)",
      "Bash(pg_isready:*)",
      "mcp__Claude_Preview__preview_start",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(*ANTHROPIC_API_KEY*)",
      "Bash(*SECRET_KEY*)",
      "Bash(*--force*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(*> /dev/*)",
      "Bash(docker run --privileged*)",
      "Bash(docker run -v /:/host*)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(ssh *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'PreToolUse: Bash command validated'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/lautarodamore/Documents/vdp && git diff --cached --name-only | grep -qE '\\.(env|key|pem|secret)' && echo 'WARNING: Staged files may contain secrets' || true"
          }
        ]
      }
    ]
  }
}
