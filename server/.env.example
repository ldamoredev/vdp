# ─── Database (required) ──────────────────────────────────
DATABASE_URL=
TEST_DATABASE_URL=

# ─── Access Control (optional, disables guard if unset) ───
ACCESS_SECRET=

# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS (comma-separated origins, defaults to allow-all) ─
# CORS_ORIGIN=http://localhost:3000,https://vdp.example.com

# ─── Agent Provider (pick one) ────────────────────────────
# Option 1: Ollama (default — no config needed for local dev)
# AGENT_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen3:4b

# Option 2: Anthropic
# AGENT_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Option 3: OpenAI-compatible (Groq, Together, Cerebras, etc.)
# AGENT_PROVIDER=openai-compatible
# OPENAI_COMPAT_BASE_URL=https://api.groq.com/openai
# OPENAI_COMPAT_API_KEY=gsk_...
# OPENAI_COMPAT_MODEL=llama-3.3-70b-versatile

# ─── Embeddings (optional) ───────────────────────────────
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text

# ─── Observability (optional) ────────────────────────────
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=vdp-server

# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_HOST=http://localhost:3001
