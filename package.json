{
  "name": "vdp",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:landing": "pnpm --filter @vdp/landing run dev",
    "dev:wallet": "pnpm --filter @vdp/wallet-frontend run dev & pnpm --filter @vdp/wallet-backend run dev",
    "dev:people": "pnpm --filter @vdp/people-frontend run dev",
    "dev:health": "pnpm --filter @vdp/health-frontend run dev",
    "dev:work": "pnpm --filter @vdp/work-frontend run dev",
    "dev:study": "pnpm --filter @vdp/study-frontend run dev",
    "build": "pnpm -r run build",
    "db:generate": "pnpm --filter @vdp/db run generate",
    "db:migrate": "pnpm --filter @vdp/db run migrate",
    "db:seed": "pnpm --filter @vdp/db run seed",
    "db:studio": "pnpm --filter @vdp/db run studio"
  }
}
